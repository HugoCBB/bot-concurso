# S3 / object storage configuration (required by app/infra/s3_client.py)
S3_ENDPOINT=https://your-s3-endpoint.example.com
S3_REGION=us-west-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=editais-bot-concurso

# Redis (cache + fila)
REDIS_URL=redis://localhost:6379/0

# Postgres (fonte de verdade) - driver async psycopg3
# Local (docker):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/concursos
#
# Supabase (prod) - use the DIRECT connection (port 5432), keep the +psycopg driver,
# and require SSL. Do NOT use the transaction pooler (port 6543) for migrations.
# DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
